APP_NAME=DBProvision
ENVIRONMENT=production

# Management DB 
MGMT_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dbprovision
MGMT_DB_SYNC_URL=postgresql://postgres:postgres@localhost:5432/dbprovision

# Redis 
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_ACCESS_KEY_ID=AKIA...your...real...key
AWS_SECRET_ACCESS_KEY=your...real...secret
AWS_REGION=us-east-1

# Values from bootstrap outputs
RDS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
RDS_SUBNET_GROUP=dbprovision-subnet-group
BACKUP_S3_BUCKET=dbprovision-backups-YOUR_ACCOUNT_ID
BACKUP_RETENTION_DAYS=30

# Terraform
TERRAFORM_DIR=../infrastructure/terraform
TERRAFORM_STATE_BUCKET=dbprovision-tf-state-YOUR_ACCOUNT_ID

# RDS defaults
RDS_INSTANCE_CLASS=db.t3.micro
RDS_ENGINE_VERSION=15.4
RDS_ALLOCATED_STORAGE=20