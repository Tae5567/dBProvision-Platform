{
  "description": "Deep-dive into a single tenant database — drill down from fleet overview",
  "editable": true,
  "graphTooltip": 1,
  "panels": [

    {
      "id": 1,
      "type": "timeseries",
      "title": "Connections Over Time",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "pg_stat_database_numbackends{instance=~\"$tenant\"}",
        "legendFormat": "Active connections",
        "refId": "A"
      },{
        "expr": "pg_settings_max_connections{instance=~\"$tenant\"}",
        "legendFormat": "Max connections",
        "refId": "B"
      }],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      }
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "sum by (instance) (rate(pg_stat_database_blks_hit{instance=~\"$tenant\"}[5m])) / (sum by (instance) (rate(pg_stat_database_blks_hit{instance=~\"$tenant\"}[5m])) + sum by (instance) (rate(pg_stat_database_blks_read{instance=~\"$tenant\"}[5m])))",
        "legendFormat": "Cache hit ratio",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },

    {
      "id": 3,
      "type": "timeseries",
      "title": "Transaction Rate (commits + rollbacks/sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{instance=~\"$tenant\"}[1m])",
          "legendFormat": "Commits/sec",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{instance=~\"$tenant\"}[1m])",
          "legendFormat": "Rollbacks/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      }
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Replication Lag",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{
        "expr": "pg_replication_lag{instance=~\"$tenant\"}",
        "legendFormat": "Replication lag",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Rows Read vs Returned (index efficiency)",
      "description": "If rows_fetched << rows_returned, you're doing sequential scans. Add indexes.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{instance=~\"$tenant\"}[1m])",
          "legendFormat": "Rows fetched (index)",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_returned{instance=~\"$tenant\"}[1m])",
          "legendFormat": "Rows returned (seq scan)",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "rows/s" } }
    },

    {
      "id": 6,
      "type": "table",
      "title": "Lock Waits",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [{
        "expr": "pg_locks_count{instance=~\"$tenant\"}",
        "legendFormat": "{{ mode }} / granted={{ granted }}",
        "refId": "A",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    }

  ],
  "templating": {
    "list": [{
      "name": "tenant",
      "type": "query",
      "datasource": "Prometheus",
      "query": "label_values(pg_up, instance)",
      "label": "Tenant Database",
      "refresh": 2,
      "sort": 1
    }]
  },
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["dbprovision", "tenant"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Tenant Detail",
  "uid": "dbprovision-tenant",
  "version": 1
}