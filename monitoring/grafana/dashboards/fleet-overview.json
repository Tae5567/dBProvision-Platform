{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "All tenant databases at a glance — connections, cache hit, disk, status",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Active Databases",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [{
        "expr": "count(pg_up == 1)",
        "legendFormat": "Active DBs",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Databases with Alerts",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "expr": "count(pg_up == 0) or vector(0)",
        "legendFormat": "Unreachable",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Total Connections (Fleet)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "area" },
      "targets": [{
        "expr": "sum(pg_stat_database_numbackends)",
        "legendFormat": "Total Connections",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 800 },
              { "color": "red", "value": 950 }
            ]
          }
        }
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Avg Cache Hit Ratio",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": { "colorMode": "background", "graphMode": "none" },
      "targets": [{
        "expr": "avg(sum by (instance) (pg_stat_database_blks_hit) / (sum by (instance) (pg_stat_database_blks_hit) + sum by (instance) (pg_stat_database_blks_read)))",
        "legendFormat": "Cache Hit %",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.90 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Connection Count per Tenant (Top 10)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [{
        "expr": "topk(10, pg_stat_database_numbackends)",
        "legendFormat": "{{ instance }}",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },

    {
      "id": 6,
      "type": "table",
      "title": "Fleet Health Table",
      "description": "One row per tenant database. Red = needs attention.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 12 },
      "options": {
        "sortBy": [{ "desc": true, "displayName": "Connections" }]
      },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "{{ instance }}",
          "refId": "connections",
          "instant": true
        },
        {
          "expr": "sum by (instance) (pg_stat_database_blks_hit) / (sum by (instance) (pg_stat_database_blks_hit) + sum by (instance) (pg_stat_database_blks_read))",
          "legendFormat": "{{ instance }}",
          "refId": "cache_hit",
          "instant": true
        },
        {
          "expr": "pg_replication_lag",
          "legendFormat": "{{ instance }}",
          "refId": "replication_lag",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #cache_hit" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "displayName", "value": "Cache Hit %" },
              {
                "id": "custom.displayMode", "value": "color-background",
                "thresholds": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": 0 },
                    { "color": "yellow", "value": 0.9 },
                    { "color": "green", "value": 0.95 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #connections" },
            "properties": [{ "id": "displayName", "value": "Connections" }]
          },
          {
            "matcher": { "id": "byName", "options": "Value #replication_lag" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "displayName", "value": "Replication Lag" }
            ]
          }
        ]
      }
    }

  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["dbprovision", "fleet"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Fleet Overview",
  "uid": "dbprovision-fleet",
  "version": 1
}